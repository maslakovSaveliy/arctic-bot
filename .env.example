# Telegram Bot API
TELEGRAM_BOT_TOKEN=your_bot_token_here
CHANNEL_ID=your_channel_id_here
CHANNEL_USERNAME=@your_channel_username
ADMIN_USER_IDS=123456789,987654321

# MongoDB
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB_NAME=telegram_bot

# MongoDB Docker (используется в docker-compose)
MONGO_ROOT_USERNAME=admin
MONGO_ROOT_PASSWORD=change_me_in_production

# Bot Settings
DEBUG=False
DEFAULT_WELCOME_MESSAGE=Добро пожаловать в наш канал!

# SMTP (для отправки заявок на консультацию)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_TO_EMAIL=feedback@example.com
SMTP_SUBJECT=Заявки квиз
